NODE_ENV=development
PORT=4000
HOST=0.0.0.0
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ALLOWED_EMAIL_DOMAINS=nileuniversity.edu.ng,nilehive.test
FRONTEND_APP_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8081,http://127.0.0.1:8080,http://127.0.0.1:8081

# Optional one-time production bootstrap reference.
# The SQL bootstrap file uses these values manually in Supabase SQL Editor.
BOOTSTRAP_ADMIN_AUTH_USER_ID=00000000-0000-0000-0000-000000000000
BOOTSTRAP_ADMIN_FULL_NAME=Club Services Admin
BOOTSTRAP_ADMIN_EMAIL=admin@nileuniversity.edu.ng

# Microsoft Graph email delivery is disabled unless this is true.
EMAIL_DELIVERY_ENABLED=false
EMAIL_PROVIDER=microsoft_graph
MICROSOFT_TENANT_ID=your-azure-tenant-id
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_SENDER_EMAIL=clubservices@nileuniversity.edu.ng
